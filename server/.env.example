# Copy to .env locally. On Render, set the same keys in Environment (do not commit real secrets).

PORT=5000
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/plm?retryWrites=true&w=majority
JWT_SECRET=use_a_long_random_string

# Frontend URL (invite links in emails). Use your Vercel URL in production.
# Example: https://your-app.vercel.app  (no trailing slash)
CLIENT_URL=http://localhost:5173

# ── Mail (server sends invites; Vercel does NOT send mail — only Render needs these) ──

# Gmail App Password (same as Google Account → Security → App passwords)
# Works great on your PC; on Render it may time out — then add RESEND_API_KEY below as backup.
GMAIL_USER=nand13112004@gmail.com
GMAIL_APP_PASSWORD=ssdjqzovltxjtllc

# Optional: backup on Render when Gmail fails (https://resend.com — free tier)
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM_EMAIL=onboarding@resend.dev
MAIL_FROM_NAME=RevoraX

# Or use a full SMTP provider instead of Gmail:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=

# Optional timeouts (ms) if connections are slow:
# SMTP_CONNECTION_TIMEOUT_MS=60000
# SMTP_SOCKET_TIMEOUT_MS=60000
