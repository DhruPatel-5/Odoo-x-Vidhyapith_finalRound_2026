# Copy this file to .env and fill in your values.
# Set these in Render → Environment → Environment Variables

PORT=5000
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/plm?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_secret
CLIENT_URL=https://your-app.vercel.app

# ── Invite emails (nodemailer) ─────────────────────────────────
# If omitted, invites still work — admin copies the link from the UI.
#
# --- Gmail (recommended): App Password only — no smtp host/port needed ---
# Create: Google Account → Security → 2-Step Verification → App passwords
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Optional for Gmail: override "From" address (defaults to GMAIL_USER)
# MAIL_FROM=
MAIL_FROM_NAME=RevoraX

# --- Or any other provider: full SMTP ---
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
